{
  "name": "@elianiva/flouride",
  "version": "1.5.0",
  "description": "A library for detecting the programming language of a code snippet.",
  "keywords": [
    "classifier",
    "classify",
    "code",
    "detection",
    "detector",
    "identifier",
    "identify",
    "language",
    "programming"
  ],
  "homepage": "https://github.com/elianiva/flouride#readme",
  "bugs": {
    "url": "https://github.com/elianiva/flouride/issues"
  },
  "license": "MIT",
  "contributors": [
    {
      "name": "elianiva",
      "email": "contact@elianiva.com",
      "url": "https://github.com/elianiva"
    }
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/elianiva/flouride.git"
  },
  "funding": [
    {
      "type": "github",
      "url": "https://github.com/sponsors/elianiva"
    }
  ],
  "directories": {
    "lib": "./src",
    "test": "./tests"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.mjs",
  "browser": "dist/index.iife.js",
  "types": "dist/index.d.mts",
  "unpkg": "dist/index.iife.js",
  "jsdelivr": "dist/index.iife.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json",
    "./*": "./*"
  },
  "scripts": {
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "test": "vp test --coverage",
    "test:watch": "vp test --watch",
    "build": "vp pack",
    "benchmark": "vp test bench --run",
    "prepare": "vp config"
  },
  "dependencies": {
    "@vitest/coverage-v8": "^4.1.6"
  },
  "devDependencies": {
    "@types/node": "^25.8.0",
    "tslib": "^2.6.3",
    "typescript": "^6.0.3",
    "vite": "catalog:",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=22.18"
  },
  "packageManager": "pnpm@11.1.2"
}
